# ---------- Chart 1: Warning timeline ----------
if not warnings_out.empty:
    fig, ax = plt.subplots(figsize=(14, 6))

    role_y = {
        "legal": 6,
        "judge": 5,
        "platform_trust": 4,
        "pr": 3,
        "social_manager": 2,
