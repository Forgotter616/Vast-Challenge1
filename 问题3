    plt.tight_layout()
    plt.savefig("task3_warning_timeline.png", dpi=160)
    plt.close()

    print("\nSaved chart: task3_warning_timeline.png")
else:
    print("\nNo warning records. Warning timeline chart was not generated.")

# ---------- Chart 2: Anomaly matrix ----------
if not anom_out.empty:
    tmp = anom_out.copy()
    tmp["flag_list"] = tmp["anomaly_flags"].str.split("|")
    tmp = tmp.explode("flag_list")

    mat = tmp.pivot_table(
        index="agent_id",
        columns="flag_list",
        values="timestamp",
        aggfunc="count",
        fill_value=0
    )

    fig, ax = plt.subplots(figsize=(12, 6))
    im = ax.imshow(mat.values, cmap="Reds", aspect="auto")

    ax.set_xticks(range(len(mat.columns)))
    ax.set_xticklabels(mat.columns, rotation=25, ha="right")
    ax.set_yticks(range(len(mat.index)))
    ax.set_yticklabels(mat.index)

    for i in range(mat.shape[0]):
        for j in range(mat.shape[1]):
            ax.text(
                j,
                i,
                mat.values[i, j],
                ha="center",
                va="center",
                color="black",
                fontsize=9
            )

    ax.set_title("Task 3B - Historical Anomaly Matrix")
    plt.colorbar(im, ax=ax, label="Count")
    plt.tight_layout()
    plt.savefig("task3_anomaly_matrix.png", dpi=160)
    plt.close()

    print("Saved chart: task3_anomaly_matrix.png")
else:
    print("No anomaly records. Anomaly matrix chart was not generated.")

