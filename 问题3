if "phase" in df.columns and "channel" in df.columns:
    ch_ct = df.groupby(["phase", "channel"]).size().unstack(fill_value=0)

    fig, ax = plt.subplots(figsize=(12, 6))
    ch_ct.T.plot(kind="bar", ax=ax)

    ax.set_title("Task 3 - Channel Distribution: Pre-crisis vs Crisis Day")
    ax.set_ylabel("Message count")
    ax.set_xlabel("Channel")
    plt.xticks(rotation=25, ha="right")
    plt.tight_layout()
    plt.savefig("task3_channel_distribution.png", dpi=160)
    plt.close()

    print("Saved chart: task3_channel_distribution.png")

