    ax.set_yticklabels(list(role_y.keys()))
    ax.set_title("Task 3A - Early Warning Signal Timeline")
    ax.set_xlabel("Time")
    ax.set_ylabel("Agent role")
    ax.legend(loc="upper left")
    ax.xaxis.set_major_formatter(mdates.DateFormatter("%m-%d %H:%M"))
